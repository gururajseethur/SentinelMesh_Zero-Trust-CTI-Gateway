# TISP Nexus frontend environment
# Copy this file to .env before starting the dev server.
# VITE_* values are embedded in the browser bundle. Never place API secrets here.

# API mode: "simulation" for deterministic offline data, "live" for tisp-proxy-backed service calls.
VITE_API_MODE=simulation

# API proxy targets. API keys live in tisp-infra/.env and are read by tisp-proxy.
VITE_PROXY_URL=http://tisp-proxy:3001
VITE_N8N_URL=http://localhost:5678

# Keycloak identity / SSO
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=tisp
VITE_KEYCLOAK_CLIENT_ID=tisp-dashboard

# Dashboard behaviour
VITE_POLLING_INTERVAL=30000

# Lab safety guardrail — shows a persistent warning banner in the UI.
# Set to "false" only after the proxy JWT verification gap is resolved
# (see tisp-proxy/README.md §Security Limitations).
VITE_LAB_MODE=true
