# TISP production configuration
# Copy to .env.prod, replace every CHANGE_ME value, and keep the file private.

TISP_DOMAIN=example.org
TISP_ADMIN_EMAIL=admin@example.org

# Keycloak identity layer
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET

# MISP ingestion layer
MISP_DB_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
MISP_DB_ROOT_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
MISP_REDIS_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
MISP_ADMIN_EMAIL=admin@example.org
MISP_ADMIN_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
MISP_ADMIN_ORG=TISP
MISP_ADMIN_ORG_UUID=CHANGE_ME_UUID
MISP_EMAIL=misp@example.org
MISP_SALT=CHANGE_ME_64_CHAR_RANDOM_SECRET
MISP_UUID=CHANGE_ME_UUID
MISP_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_RANDOM_SECRET
MISP_GPG_PASSPHRASE=CHANGE_ME_64_CHAR_RANDOM_SECRET

# OpenCTI correlation layer
OPENCTI_ADMIN_EMAIL=admin@example.org
OPENCTI_ADMIN_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
OPENCTI_ADMIN_TOKEN=CHANGE_ME_UUID_OR_64_CHAR_RANDOM_SECRET
MINIO_ACCESS_KEY=tispminioadmin
MINIO_SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_SECRET
RABBITMQ_DEFAULT_USER=opencti
RABBITMQ_DEFAULT_PASS=CHANGE_ME_64_CHAR_RANDOM_SECRET
ELASTIC_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
OPENCTI_ES_JAVA_OPTS=-Xms2g -Xmx2g

# TheHive incident response layer
THEHIVE_APPLICATION_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
THEHIVE_ELASTIC_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
THEHIVE_ES_JAVA_OPTS=-Xms2g -Xmx2g

# n8n automation layer
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_64_CHAR_RANDOM_SECRET
N8N_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_RANDOM_SECRET
