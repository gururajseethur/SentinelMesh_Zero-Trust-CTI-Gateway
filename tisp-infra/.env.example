# TISP local lab configuration
# Copy to .env and replace every CHANGE_ME value before deployment.

TISP_DOMAIN=localhost

# Keycloak identity layer
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_keycloak_db_password_32_chars
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password_32_chars

# MISP ingestion layer
MISP_DB_PASSWORD=CHANGE_ME_misp_db_password_32_chars
MISP_DB_ROOT_PASSWORD=CHANGE_ME_misp_root_password_32_chars
MISP_REDIS_PASSWORD=CHANGE_ME_misp_redis_password_32_chars
MISP_ADMIN_EMAIL=admin@tisp.local
MISP_ADMIN_PASSWORD=CHANGE_ME_misp_admin_password_32_chars
MISP_ADMIN_ORG=TISP
MISP_ADMIN_ORG_UUID=CHANGE_ME_misp_admin_org_uuid
MISP_EMAIL=misp@tisp.local
MISP_SALT=CHANGE_ME_misp_salt_32_chars
MISP_UUID=CHANGE_ME_misp_instance_uuid
MISP_ENCRYPTION_KEY=CHANGE_ME_misp_encryption_key_32_chars
MISP_GPG_PASSPHRASE=CHANGE_ME_misp_gpg_passphrase_32_chars
MISP_API_KEY=CHANGE_ME_misp_api_key

# OpenCTI correlation layer
OPENCTI_ADMIN_EMAIL=admin@tisp.local
OPENCTI_ADMIN_PASSWORD=CHANGE_ME_opencti_admin_password_32_chars
OPENCTI_ADMIN_TOKEN=CHANGE_ME_opencti_admin_token_uuid_or_64_chars
OPENCTI_TOKEN=CHANGE_ME_opencti_api_token
MINIO_ACCESS_KEY=tispminioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_32_chars
RABBITMQ_DEFAULT_USER=opencti
RABBITMQ_DEFAULT_PASS=CHANGE_ME_rabbitmq_password_32_chars

# TheHive incident response layer
THEHIVE_APPLICATION_SECRET=CHANGE_ME_thehive_application_secret_32_chars
THEHIVE_ELASTICSEARCH_USER=elastic
THEHIVE_ELASTIC_PASSWORD=CHANGE_ME_thehive_elasticsearch_password_32_chars
THEHIVE_API_KEY=CHANGE_ME_thehive_api_key

# n8n automation layer
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_password_32_chars
N8N_ENCRYPTION_KEY=CHANGE_ME_n8n_encryption_key_32_chars_minimum

# Observability layer
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password_32_chars
